# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Optional: phone number for authentication (can be a bot token too)
TELEGRAM_PHONE=+1234567890

# Server settings
HOST=0.0.0.0
PORT=8000

# SQLite database path
DB_PATH=telegram_search.db

# How many messages to fetch per channel on initial scrape
INITIAL_SCRAPE_LIMIT=1000
